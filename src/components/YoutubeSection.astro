---
import { site } from "../lib/config";
import { fetchLatestVideos, type Video } from "../lib/youtube";

const videos: Video[] = await fetchLatestVideos(site.youtube.channelId, 6);

function formatDate(iso: string): string {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
}
---

<section id="youtube" class="py-24 md:py-32 border-t border-border bg-elevated">
  <div class="container-wide">
    <div class="grid md:grid-cols-12 gap-8 mb-14 items-end">
      <div class="md:col-span-7">
        <p class="eyebrow mb-4">01 · YouTube</p>
        <h2 class="text-4xl md:text-6xl">
          Je documente ce que <span class="italic text-accent">je découvre</span>.
        </h2>
      </div>
      <div class="md:col-span-5">
        <p class="text-lg text-ink-secondary mb-4">
          Outils et méthodes que j'utilise pour décupler les capacités de l'IA.
        </p>
        <a
          href={site.youtube.channelUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm text-ink-secondary hover:text-accent transition-colors"
        >
          Voir la chaîne <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    {videos.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-border-strong bg-surface p-12 text-center text-ink-muted">
        <p class="text-lg text-ink mb-2">Les premières vidéos arrivent.</p>
        <p>La grille s'alimentera automatiquement dès la publication.</p>
        <a href={site.youtube.channelUrl} class="inline-block mt-6 btn-secondary" target="_blank" rel="noopener">
          Voir la chaîne <span aria-hidden="true">→</span>
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((v) => (
          <a href={v.url} target="_blank" rel="noopener" class="group block">
            <div class="aspect-video overflow-hidden rounded-xl border border-border mb-4 bg-surface">
              <img
                src={v.thumbnail}
                alt={v.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
            <h3 class="text-lg leading-snug group-hover:text-accent transition-colors line-clamp-2 font-sans font-medium">
              {v.title}
            </h3>
            <p class="text-xs text-ink-muted mt-2 font-mono">
              {formatDate(v.publishedAt)}
            </p>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
