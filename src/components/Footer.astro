---
import { site } from "../lib/config";
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-16 bg-elevated">
  <div class="container-wide">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-2">
        <p class="font-logo text-3xl mb-3">Florian Brignoli</p>
        <p class="text-sm text-ink-secondary max-w-xs">
          J'aide les dirigeants de PME et les freelances à intégrer l'IA dans leur business.
        </p>
      </div>

      <div>
        <p class="eyebrow mb-4">Naviguer</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#youtube" class="text-ink-secondary hover:text-ink transition-colors">YouTube</a></li>
          <li><a href="#approche" class="text-ink-secondary hover:text-ink transition-colors">L'approche</a></li>
          <li><a href="#ressources" class="text-ink-secondary hover:text-ink transition-colors">Ressources</a></li>
          <li><a href={site.cal.url} target="_blank" rel="noopener" class="text-ink-secondary hover:text-ink transition-colors">Prendre rendez-vous</a></li>
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-4">Suivre</p>
        <ul class="space-y-2 text-sm">
          {site.socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener" class="text-ink-secondary hover:text-ink transition-colors">
                {s.label} <span aria-hidden="true">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-border flex flex-col sm:flex-row justify-between gap-3 text-xs text-ink-muted font-mono">
      <p>
        © {year} Florian Brignoli ·
        <a href="https://amplixy.com" target="_blank" rel="noopener" class="hover:text-ink transition-colors">
          Amplixy EURL
        </a>
      </p>
      <p>
        <a href="/mentions-legales" class="hover:text-ink transition-colors">Mentions légales</a>
      </p>
    </div>
  </div>
</footer>
