---
import { site } from "../lib/config";
---

<nav class="sticky top-0 z-40 backdrop-blur-md bg-bg/85 border-b border-border">
  <div class="container-wide flex items-center justify-between h-16">
    <a href="/" class="font-logo text-2xl italic hover:text-accent transition-colors">
      Florian Brignoli
    </a>

    <div class="hidden md:flex items-center gap-8 text-sm text-ink-secondary">
      <a href="#youtube" class="hover:text-ink transition-colors">YouTube</a>
      <a href="#approche" class="hover:text-ink transition-colors">L'approche</a>
      <a href="#ressources" class="hover:text-ink transition-colors">Outils</a>
    </div>

    <a
      href={site.cal.url}
      target="_blank"
      rel="noopener"
      class="btn-primary text-sm py-2.5 px-4"
    >
      Prendre rendez-vous
    </a>
  </div>
</nav>
